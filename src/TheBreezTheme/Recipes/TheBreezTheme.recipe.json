          "ContentType": "Menu",
          "DisplayText": "Main Menu",
          "Published": true,
          "Latest": true,
          "Owner": "admin",
          "Content": {
            "TitlePart": { "Title": "Main Menu" },
            "AliasPart": { "Alias": "main-menu" },
            "MenuItemsListPart": {
