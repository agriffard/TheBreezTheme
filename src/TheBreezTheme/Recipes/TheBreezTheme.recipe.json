          "HtmlBodyPart": { "Html": "Skip links, focus rings, ARIA labels and semantic markup baked in." }
        },
        {
          "ContentItemId": "feature-darkmode",
          "ContentItemVersionId": "feature-darkmode-v1",
          "ContentType": "Feature",
          "DisplayText": "Dark mode",
          "Latest": true,
          "Published": true,
          "Owner": "admin",
          "Author": "admin",
          "CreatedUtc": "2026-05-01T10:02:00Z",
          "TitlePart": { "Title": "Dark mode" },
          "HtmlBodyPart": { "Html": "Respects system preference and remembers your choice across visits." }
        },
        {
          "ContentItemId": "feature-responsive",
          "ContentItemVersionId": "feature-responsive-v1",
          "ContentType": "Feature",
          "DisplayText": "Responsive",
          "Latest": true,
          "Published": true,
          "Owner": "admin",
