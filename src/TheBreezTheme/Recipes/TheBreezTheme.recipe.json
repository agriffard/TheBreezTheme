          "TitlePart": { "Title": "Responsive" },
          "HtmlBodyPart": { "Html": "Fluid grids and breakpoints from mobile to wide desktop." }
        },
        {
          "ContentItemId": "blog-main-en",
          "ContentItemVersionId": "blog-main-en-v1",
          "ContentType": "Blog",
          "DisplayText": "Blog",
          "Latest": true,
          "Published": true,
          "Owner": "admin",
          "Author": "admin",
          "TitlePart": { "Title": "Blog" },
          "AutoroutePart": { "Path": "blog", "SetHomepage": false },
          "ListPart": {},
          "LocalizationPart": { "Culture": "en", "LocalizationSet": "blog" }
        },
        {
          "ContentItemId": "blog-post-getting-started",
          "ContentItemVersionId": "blog-post-getting-started-v1",
          "ContentType": "BlogPost",
          "DisplayText": "Getting started with Orchard Core",
          "Latest": true,
          "Published": true,
          "Owner": "admin",
          "Author": "admin",
          "CreatedUtc": "2026-05-28T10:00:00Z",
          "TitlePart": { "Title": "Getting started with Orchard Core" },
          "AutoroutePart": { "Path": "blog/getting-started-with-orchard-core", "SetHomepage": false },
          "HtmlBodyPart": { "Html": "<p>Install, configure and ship your first Orchard Core site using the Breez theme as a starting point.</p>" },
          "ContainedPart": { "ListContentItemId": "blog-main-en", "Order": 0 },
          "LocalizationPart": { "Culture": "en", "LocalizationSet": "getting-started" }
        },
        {
          "ContentItemId": "blog-post-oklch",
          "ContentItemVersionId": "blog-post-oklch-v1",
          "ContentType": "BlogPost",
          "DisplayText": "Theming with OKLCH colors",
          "Latest": true,
          "Published": true,
          "Owner": "admin",
          "Author": "admin",
          "CreatedUtc": "2026-05-20T10:00:00Z",
          "TitlePart": { "Title": "Theming with OKLCH colors" },
          "AutoroutePart": { "Path": "blog/theming-with-oklch-colors", "SetHomepage": false },
