{
  "name": "TheBreezTheme",
  "displayName": "The Breez Theme",
  "description": "Apply the Breez theme and seed demo content.",
  "author": "Antoine",
  "website": "https://github.com/agriffard/TheBreezTheme",
  "version": "1.0.0",
  "issetuprecipe": true,
  "categories": [ "default" ],
  "tags": [ "theme", "tailwind" ],
  "steps": [
    {
      "name": "feature",
      "enable": [
        "OrchardCore.Settings",
        "OrchardCore.Admin",
        "OrchardCore.Contents",
        "OrchardCore.Liquid",
        "OrchardCore.Templates",
        "OrchardCore.ContentTypes",
        "OrchardCore.Alias",
        "OrchardCore.Autoroute",
        "OrchardCore.ContentFields",
        "OrchardCore.ContentPreview",
        "OrchardCore.Contents.FileContentDefinition",
        "OrchardCore.CustomSettings",
        "OrchardCore.Deployment",
        "OrchardCore.Deployment.Remote",
        "OrchardCore.Diagnostics",
        "OrchardCore.DynamicCache",
        "OrchardCore.Resources",
        "OrchardCore.Widgets",
        "OrchardCore.Features",
        "OrchardCore.Feeds",
        "OrchardCore.Flows",
        "OrchardCore.HomeRoute",
        "OrchardCore.Html",
        "OrchardCore.Indexing",
        "OrchardCore.Scripting",
        "OrchardCore.Layers",
        "OrchardCore.Lists",
        "OrchardCore.Lucene",
        "OrchardCore.Markdown",
        "OrchardCore.Media",
        "OrchardCore.Title",
        "OrchardCore.Menu",
        "OrchardCore.Navigation",
        "OrchardCore.Queries",
        "OrchardCore.Queries.Sql",
        "OrchardCore.Users",
        "OrchardCore.Recipes",
        "OrchardCore.Roles",
        "OrchardCore.Themes",
        "TheAdmin",
        "TheBreezTheme"
      ]
    },
    {
      "name": "themes",
      "Site": "TheBreezTheme",
      "Admin": "TheAdmin"
    },
    {
      "name": "ContentDefinition",
      "ContentTypes": [
        {
          "Name": "Page",
          "DisplayName": "Page",
          "Settings": {
            "ContentTypeSettings": { "Creatable": true, "Listable": true, "Draftable": true, "Versionable": true },
            "Stereotype": "Content"
          },
          "ContentTypePartDefinitionRecords": [
            { "PartName": "TitlePart", "Name": "TitlePart" },
            { "PartName": "HtmlBodyPart", "Name": "HtmlBodyPart" },
            { "PartName": "AutoroutePart", "Name": "AutoroutePart", "Settings": { "AutoroutePartSettings": { "AllowCustomPath": true, "Pattern": "{{ ContentItem | display_text | slugify }}", "ShowHomepageOption": true } } },
            { "PartName": "LocalizationPart", "Name": "LocalizationPart" }
          ]
        },
        {
          "Name": "BlogPost",
          "DisplayName": "Blog Post",
          "Settings": {
            "ContentTypeSettings": { "Creatable": true, "Listable": true, "Draftable": true, "Versionable": true },
            "Stereotype": "Content"
          },
          "ContentTypePartDefinitionRecords": [
            { "PartName": "TitlePart", "Name": "TitlePart" },
            { "PartName": "HtmlBodyPart", "Name": "HtmlBodyPart" },
            { "PartName": "AutoroutePart", "Name": "AutoroutePart", "Settings": { "AutoroutePartSettings": { "AllowCustomPath": true, "Pattern": "blog/{{ ContentItem | display_text | slugify }}" } } },
            { "PartName": "LocalizationPart", "Name": "LocalizationPart" }
          ]
        },
        {
          "Name": "Blog",
          "DisplayName": "Blog",
          "Settings": {
            "ContentTypeSettings": { "Creatable": true, "Listable": true, "Versionable": true },
            "Stereotype": "Content"
          },
          "ContentTypePartDefinitionRecords": [
            { "PartName": "TitlePart", "Name": "TitlePart" },
            { "PartName": "ListPart", "Name": "ListPart", "Settings": { "ListPartSettings": { "ContainedContentTypes": [ "BlogPost" ], "EnableOrdering": false } } },
            { "PartName": "AutoroutePart", "Name": "AutoroutePart", "Settings": { "AutoroutePartSettings": { "AllowCustomPath": true, "Pattern": "{{ ContentItem | display_text | slugify }}", "AllowRouteContainedItems": true } } },
            { "PartName": "LocalizationPart", "Name": "LocalizationPart" }
          ]
        },
        {
          "Name": "Feature",
          "DisplayName": "Feature",
          "Settings": {
            "ContentTypeSettings": { "Creatable": true, "Listable": true, "Draftable": true, "Versionable": true },
            "Stereotype": "Content"
          },
          "ContentTypePartDefinitionRecords": [
            { "PartName": "TitlePart", "Name": "TitlePart" },
            { "PartName": "HtmlBodyPart", "Name": "HtmlBodyPart" }
          ]
        }
      ]
    },
    {
      "name": "queries",
      "Queries": [
        {
          "Source": "Sql",
          "Name": "HomeFeatures",
          "ReturnContentItems": true,
          "Template": "SELECT DocumentId FROM ContentItemIndex WHERE ContentType = 'Feature' AND Published = 1 AND Latest = 1 ORDER BY CreatedUtc"
        },
        {
          "Source": "Sql",
          "Name": "LatestBlogPosts",
          "ReturnContentItems": true,
          "Template": "SELECT DocumentId FROM ContentItemIndex WHERE ContentType = 'BlogPost' AND Published = 1 AND Latest = 1 ORDER BY CreatedUtc DESC"
        }
      ]
    },
    {
      "name": "Settings",
      "HomeRoute": {
        "Action": "Display",
        "Controller": "Item",
        "Area": "OrchardCore.Contents",
        "ContentItemId": "page-home-en"
      }
    },
    {
      "name": "Roles",
      "Roles": [
        {
          "Name": "Anonymous",
          "Description": "Anonymous role",
          "Permissions": [ "ViewContent" ]
        },
        {
          "Name": "Authenticated",
          "Description": "Authenticated role",
          "Permissions": [ "ViewContent" ]
        }
      ]
    },
    {
      "name": "Content",
      "Data": [
        {
          "ContentItemId": "page-home-en",
          "ContentItemVersionId": "page-home-en-v1",
          "ContentType": "Page",
          "DisplayText": "Welcome",
          "Latest": true,
          "Published": true,
          "Owner": "admin",
          "Author": "admin",
          "TitlePart": { "Title": "Welcome" },
          "AutoroutePart": { "Path": "welcome", "SetHomepage": false },
          "HtmlBodyPart": { "Html": "<h1>Welcome to TheBreez Sample</h1><p>This site was provisioned automatically with Orchard Core AutoSetup using TheBreezTheme.</p>" },
          "LocalizationPart": { "Culture": "en", "LocalizationSet": "home" }
        },
        {
          "ContentItemId": "page-home-fr",
          "ContentItemVersionId": "page-home-fr-v1",
          "ContentType": "Page",
          "DisplayText": "Bienvenue",
          "Latest": true,
          "Published": true,
          "Owner": "admin",
          "Author": "admin",
          "TitlePart": { "Title": "Bienvenue" },
          "AutoroutePart": { "Path": "fr/bienvenue", "SetHomepage": false },
          "HtmlBodyPart": { "Html": "<h1>Bienvenue sur TheBreez Sample</h1><p>Ce site a été provisionné automatiquement avec Orchard Core AutoSetup en utilisant TheBreezTheme.</p>" },
          "LocalizationPart": { "Culture": "fr", "LocalizationSet": "home" }
        },
        {
          "ContentItemId": "menu-main",
          "ContentItemVersionId": "menu-main-v1",
          "ContentType": "Menu",
          "DisplayText": "Main Menu",
          "Latest": true,
          "Published": true,
          "Owner": "admin",
          "Author": "admin",
          "TitlePart": { "Title": "Main Menu" },
          "AliasPart": { "Alias": "main-menu" },
          "MenuItemsListPart": {
            "MenuItems": [
              {
                "ContentType": "LinkMenuItem",
                "ContentItemId": "menu-item-home",
                "DisplayText": "Home",
                "LinkMenuItemPart": { "Name": "Home", "Url": "~/" }
              },
              {
                "ContentType": "LinkMenuItem",
                "ContentItemId": "menu-item-features",
                "DisplayText": "Features",
                "LinkMenuItemPart": { "Name": "Features", "Url": "~/#features" }
              },
              {
                "ContentType": "LinkMenuItem",
                "ContentItemId": "menu-item-blog",
                "DisplayText": "Blog",
                "LinkMenuItemPart": { "Name": "Blog", "Url": "~/blog" }
              },
              {
                "ContentType": "LinkMenuItem",
                "ContentItemId": "menu-item-contact",
                "DisplayText": "Contact",
                "LinkMenuItemPart": { "Name": "Contact", "Url": "~/#contact" }
              }
            ]
          }
        },
        {
          "ContentItemId": "feature-fast",
          "ContentItemVersionId": "feature-fast-v1",
          "ContentType": "Feature",
          "DisplayText": "Fast",
          "Latest": true,
          "Published": true,
          "Owner": "admin",
          "Author": "admin",
          "CreatedUtc": "2026-05-01T10:00:00Z",
          "TitlePart": { "Title": "Fast" },
          "HtmlBodyPart": { "Html": "Tiny CSS footprint, no runtime framework. Pages load instantly." }
        },
        {
          "ContentItemId": "feature-accessible",
          "ContentItemVersionId": "feature-accessible-v1",
          "ContentType": "Feature",
          "DisplayText": "Accessible",
          "Latest": true,
          "Published": true,
          "Owner": "admin",
          "Author": "admin",
          "CreatedUtc": "2026-05-01T10:01:00Z",
