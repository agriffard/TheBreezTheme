        },
        {
          "ContentItemId": "blog-post-accessibility",
          "ContentItemVersionId": "blog-post-accessibility-v1",
          "ContentType": "BlogPost",
          "DisplayText": "Accessibility checklist",
          "Latest": true,
          "Published": true,
          "Owner": "admin",
          "Author": "admin",
          "CreatedUtc": "2026-05-12T10:00:00Z",
          "TitlePart": { "Title": "Accessibility checklist" },
          "AutoroutePart": { "Path": "blog/accessibility-checklist", "SetHomepage": false },
          "HtmlBodyPart": { "Html": "<p>A practical checklist to make sure every page you publish is usable by everyone.</p>" },
          "ContainedPart": { "ListContentItemId": "blog-main-en", "Order": 2 },
          "LocalizationPart": { "Culture": "en", "LocalizationSet": "accessibility-checklist" }
        }
      ]
    }
  ]
}
